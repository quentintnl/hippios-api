NODE_ENV=development
PORT=3000

# Frontend
NEXT_PUBLIC_API_URL=your_api_url_here

# Postgres
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here
DB_HOST=your_db_host_here
DB_PORT=your_db_port_here

# Better Auth
# Génère un secret avec: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_a_long_random_string
BETTER_AUTH_URL=your_better_auth_url_here

# Origines autorisées à appeler l'API (séparées par des virgules)
# En local, front et API ne partagent pas de domaine racine -> sameSite=lax suffit
# tant que les ports sont différents sur localhost (cookie non scoppé à un domaine).
TRUSTED_ORIGINS=your_trusted_origins_here

# En production uniquement : domaine racine partagé entre front et API,
# avec un point en préfixe, ex: .hippios.com
# Laisser vide en local.
COOKIE_DOMAIN=